{
  "name": "subcat",
  "version": "1.0.4",
  "description": "Get notified when a GitHub Actions CI run finishes",
  "author": "Samuel Fialho",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "test": "NODE_NO_WARNINGS=1 jest",
    "build:mac": "electron-builder --mac --config.mac.target=dmg",
    "postinstall": "electron-builder install-app-deps && plutil -replace CFBundleName -string SubCat node_modules/electron/dist/Electron.app/Contents/Info.plist && plutil -replace CFBundleDisplayName -string SubCat node_modules/electron/dist/Electron.app/Contents/Info.plist"
  },
  "build": {
    "appId": "com.samuelfialho.subcat",
    "productName": "SubCat",
    "asar": true,
    "asarUnpack": [
      "**/better-sqlite3/**",
      "**/*.node"
    ],
    "mac": {
      "icon": "assets/Icon-iOS-Default-1024x1024@1x.png",
      "category": "public.app-category.developer-tools",
      "identity": "Developer ID Application: Samuel Fialho (49Y5FW82WK)",
      "notarize": {
        "teamId": "49Y5FW82WK"
      }
    },
    "publish": {
      "provider": "github",
      "owner": "semisse",
      "repo": "subcat"
    },
    "files": [
      "**/*",
      "!tests/**",
      "!.github/**",
      "!**/*.test.js",
      "!**/.*"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "electron-updater": "^6.8.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testEnvironmentOptions": {
      "nodeOptions": "--no-warnings"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "jest": "^30.3.0"
  }
}
