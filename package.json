{
  "name": "subcat",
  "version": "1.0.0",
  "description": "Get notified when a GitHub Actions CI run finishes",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "test": "jest",
    "build:mac": "electron-builder --mac --config.mac.target=dmg",
    "postinstall": "electron-rebuild && plutil -replace CFBundleName -string SubCat node_modules/electron/dist/Electron.app/Contents/Info.plist && plutil -replace CFBundleDisplayName -string SubCat node_modules/electron/dist/Electron.app/Contents/Info.plist"
  },
  "build": {
    "appId": "com.samuelfialho.subcat",
    "productName": "SubCat",
    "asar": true,
    "asarUnpack": [
      "**/better-sqlite3/**",
      "**/*.node"
    ],
    "mac": {
      "icon": "assets/Icon-iOS-Default-1024x1024@1x.png",
      "category": "public.app-category.developer-tools"
    },
    "files": [
      "**/*",
      "!tests/**",
      "!.github/**",
      "!**/*.test.js",
      "!**/.*"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "electron": "^35.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron-builder": "^25.0.0",
    "electron-reload": "^2.0.0-alpha.1",
    "jest": "^30.3.0"
  }
}
