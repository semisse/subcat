{
  "name": "subcat",
  "version": "1.1.1",
  "description": "Get notified when a GitHub Actions CI run finishes",
  "author": "Samuel Fialho",
  "main": "src/electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "test": "NODE_NO_WARNINGS=1 jest",
    "test:coverage": "NODE_NO_WARNINGS=1 jest --coverage",
    "lint": "eslint src/ renderer/",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac --config.mac.target=dmg",
    "build:linux": "electron-builder --linux",
    "postinstall": "electron-builder install-app-deps && ([[ \"$OSTYPE\" == \"darwin\"* ]] && plutil -replace CFBundleName -string SubCat node_modules/electron/dist/Electron.app/Contents/Info.plist && plutil -replace CFBundleDisplayName -string SubCat node_modules/electron/dist/Electron.app/Contents/Info.plist || true)"
  },
  "build": {
    "appId": "com.samuelfialho.subcat",
    "productName": "SubCat",
    "asar": true,
    "asarUnpack": [
      "**/better-sqlite3/**",
      "**/*.node"
    ],
    "mac": {
      "icon": "assets/Icon-iOS-Default-1024x1024@1x.png",
      "category": "public.app-category.developer-tools",
      "identity": "Samuel Fialho (49Y5FW82WK)",
      "notarize": true
    },
    "linux": {
      "icon": "assets",
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "maintainer": "Samuel Fialho",
      "synopsis": "SubCat watches GitHub Actions runs and investigates flaky tests",
      "description": "Get notified when a GitHub Actions CI run finishes and investigate flaky tests automatically."
    },
    "publish": {
      "provider": "github",
      "owner": "semisse",
      "repo": "subcat"
    },
    "files": [
      "**/*",
      "!tests/**",
      "!.github/**",
      "!**/*.test.js",
      "!**/.*"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "electron-updater": "^6.8.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testEnvironmentOptions": {
      "nodeOptions": "--no-warnings"
    },
    "collectCoverageFrom": [
      "src/core/**/*.js",
      "src/db/**/*.js",
      "src/electron/ipc/**/*.js"
    ],
    "coverageReporters": [
      "text",
      "text-summary"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^10.2.0",
    "eslint-plugin-jest": "^29.15.1",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0"
  }
}
